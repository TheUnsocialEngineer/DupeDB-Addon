{
  "schemaVersion": 1,
  "id": "dupedb",
  "version": "${version}",
  "name": "DupeDB Addon",
  "description": "Search DupeDB for exploits matching server plugins.",
  "authors": [
    "jackywacky"
  ],
  "contact": {
    "sources": "https://github.com/MeteorDevelopment/meteor-addon-template"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.jackywacky.dupedb.AddonTemplate"
    ]
  },
  "mixins": [
    "dupedb.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
